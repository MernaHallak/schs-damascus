generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Article {
  id               String                @id @default(cuid())
  title            String
  slug             String                @unique
  excerpt          String
  contentMarkdown  String
  author           String                @default("فريق العيادة التخصصية للسمع والنطق")
  isPublished      Boolean               @default(false)
  publishedAt      DateTime?
  coverImageBase64 String?
  coverImageAlt    String?
  slugRedirects    ArticleSlugRedirect[]
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
 galleryImages ArticleGalleryImage[]
}

model ArticleSlugRedirect {
  id        String   @id @default(cuid())
  fromSlug  String   @unique
  articleId String
  article   Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([articleId])
}


model ArticleGalleryImage {
  id          String   @id @default(cuid())
  articleId   String
  imageBase64 String
  imageAlt    String?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())

  article     Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@index([articleId, sortOrder])
}